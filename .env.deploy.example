# Copy to .env.deploy and fill in values ( .env.deploy is gitignored )

DEPLOY_USER=deploy
DEPLOY_HOST=example.com
DEPLOY_PATH=/var/www/daodejing

# Optional: non-default SSH port
# DEPLOY_PORT=2222

# Optional: extra rsync flags (space-separated, quoted in .env if needed)
# RSYNC_EXTRA_ARGS="--chmod=D755,F644"
